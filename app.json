{
  "expo": {
    "name": "MyMoney",
    "slug": "mymoney-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/MyMoney_icon.png",
    "scheme": "mymoneyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mymoney",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundImage": "./assets/images/Background_icon.png",
        "foregroundImage": "./assets/images/MyMoney_icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Background_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5cd4c7be-8ae0-40ae-9576-50a68c4b324c"
      }
    },
    "owner": "rakibshahriar"
  }
}
